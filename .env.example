# =========================
# Core Django
# =========================
SECRET_KEY=change-me-in-production
DEBUG=False

# Comma-separated hosts
ALLOWED_HOSTS=localhost,127.0.0.1,courseadminofadmin-production.up.railway.app
PLATFORM_HOSTS=localhost,127.0.0.1
PLATFORM_BASE_DOMAIN=courseforge.katek-ai.com

# Set to True only behind trusted proxy/load balancer if needed
ALLOW_ALL_HOSTS=False

# =========================
# Database / Cache
# =========================
# Railway PostgreSQL example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# db (shared/persistent) or locmem (ephemeral/preview)
CACHE_BACKEND=db

# =========================
# App APIs
# =========================
OPENAI_API_KEY=

# =========================
# Gunicorn / Railway runtime
# =========================
WEB_CONCURRENCY=2
GUNICORN_WORKER_CLASS=gthread
GUNICORN_THREADS=2
GUNICORN_WORKER_CONNECTIONS=1000
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=2
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
LOG_LEVEL=info

# =========================
# Protective throttling
# =========================
ENABLE_PROTECTIVE_THROTTLE=True

# Per-IP and global limits used by ProtectiveThrottleMiddleware
THROTTLE_LOGIN_PER_MIN=30
THROTTLE_LOGIN_GLOBAL_PER_MIN=300
THROTTLE_REGISTER_PER_MIN=12
THROTTLE_REGISTER_GLOBAL_PER_MIN=120
THROTTLE_AI_GENERATE_PER_MIN=8
THROTTLE_AI_GENERATE_GLOBAL_PER_MIN=60
THROTTLE_TRANSCRIBE_PER_5MIN=6
THROTTLE_TRANSCRIBE_GLOBAL_PER_5MIN=40
